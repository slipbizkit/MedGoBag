# Copy to .env and fill in your values — never commit .env to git

# Neon Postgres connection string (from your Neon dashboard → Connection Details)
DATABASE_URL=postgresql://username:password@ep-xxx-yyy.us-east-1.aws.neon.tech/neondb?sslmode=require

# Random secret for signing JWTs — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# Local dev port
PORT=3001

NODE_ENV=development

# Frontend origin for CORS (update to your Vercel frontend URL in production)
FRONTEND_URL=http://localhost:5173
